{
  "version": "2.0.0",
  "tasks": [
    {
      // Build một lần: compile TypeScript + Vite webview
      "label": "compile",
      "dependsOn": [
        "compile:extension",
        "compile:webview"
      ],
      "dependsOrder": "sequence",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "compile:extension",
      "type": "npm",
      "script": "compile:extension",
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "compile:webview",
      "type": "npm",
      "script": "compile:webview",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      // Watch cả hai — dùng với "Watch & Debug Extension"
      "label": "watch",
      "dependsOn": [
        "watch:extension",
        "watch:webview"
      ],
      "dependsOrder": "parallel",
      "group": "build",
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "watch:extension",
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting compilation in watch mode",
          "endsPattern": "Found 0 errors\\. Watching for file changes"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "watch:webview",
      "type": "npm",
      "script": "watch:webview",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^(.*):(\\d+):(\\d+): (error): (.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "vite",
          "endsPattern": "built in"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    }
  ]
}