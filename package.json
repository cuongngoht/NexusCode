{
  "name": "nexus-code",
  "displayName": "Nexus Code",
  "publisher": "NexusCode",
  "description": "A chat cockpit that routes prompts to installed CLI coding agents",
  "version": "1.0.0-beta",
  "icon": "media/extension-icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning",
    "AI",
    "Other",
    "Programming Languages"
  ],
  "activationEvents": [
    "onView:nexus.chatView",
    "onCommand:nexus.createWorkflowAgent"
  ],
  "main": "./out/extension.js",
  "bin": {
    "nexus": "./out/cli/index.js"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nexus",
          "title": "Nexus",
          "icon": "media/nexus.svg"
        }
      ],
      "secondarySidebar": [
        {
          "id": "nexus-secondary",
          "title": "Nexus",
          "icon": "media/nexus.svg"
        }
      ]
    },
    "views": {
      "nexus": [
        {
          "id": "nexus.launcherView",
          "name": "Nexus",
          "type": "tree",
          "visibility": "visible"
        }
      ],
      "nexus-secondary": [
        {
          "id": "nexus.chatView",
          "name": "Chat",
          "type": "webview",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "nexus.openChat",
        "title": "Nexus: Open Chat"
      },
      {
        "command": "nexus.openSettings",
        "title": "Nexus: Open Settings"
      },
      {
        "command": "nexus.createWorkflowAgent",
        "title": "Nexus: Create Workflow Agent",
        "category": "Nexus"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "nexus.createWorkflowAgent",
          "when": "explorerResourceIsFolder && resourceFilename == agents && resourceDirname =~ /(^|[\\\\/])\\.nexus$/",
          "group": "navigation@90"
        }
      ]
    },
    "configuration": {
      "title": "Nexus Code",
      "properties": {
        "nexus.defaultProvider": {
          "type": "string",
          "default": "nexus",
          "enum": [
            "nexus",
            "auto",
            "codex",
            "claude",
            "antigravity",
            "copilot",
            "aider",
            "custom",
            "grok"
          ],
          "description": "The default CLI provider to use when routing tasks."
        },
        "nexus.customProvider.command": {
          "type": "string",
          "default": "",
          "description": "Executable for the custom provider. Use {{prompt}} as a placeholder."
        },
        "nexus.customProvider.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Arguments for the custom provider. Use {{prompt}} in any element as a placeholder."
        },
        "nexus.enablePromptEnhancement": {
          "type": "boolean",
          "default": true,
          "description": "Prepend workspace context to prompts before sending to the provider."
        },
        "nexus.showRawOutput": {
          "type": "boolean",
          "default": false,
          "description": "Show unfiltered stdout/stderr alongside parsed output."
        },
        "nexus.runGitStatusAfterTask": {
          "type": "boolean",
          "default": true,
          "description": "Run git status after each task completes and show changed files."
        },
        "nexus.mcp.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Nexus MCP tool layer."
        },
        "nexus.mcp.autoSelectPreset": {
          "type": "boolean",
          "default": true,
          "description": "Allow Nexus to select the best MCP preset based on task intent."
        },
        "nexus.mcp.requireApprovalForHighRiskTools": {
          "type": "boolean",
          "default": true,
          "description": "Require approval before high-risk MCP tool calls."
        },
        "nexus.mcp.maxResultChars": {
          "type": "number",
          "default": 6000,
          "description": "Maximum characters injected from MCP result into agent prompt."
        },
        "nexus.mcp.maxRoundsPerTask": {
          "type": "number",
          "default": 1,
          "description": "Maximum MCP tool-use rounds per task."
        },
        "nexus.mcp.presets.microsoftLearn.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Microsoft Learn MCP preset for official Microsoft documentation."
        },
        "nexus.mcp.presets.context7.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Context7 MCP preset for up-to-date library documentation."
        },
        "nexus.mcp.presets.context7.apiKey": {
          "type": "string",
          "default": "",
          "description": "Optional Context7 API key."
        },
        "nexus.subagents.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Nexus subagent layer (runs focused pre-agents before main agent)."
        },
        "nexus.subagents.maxRuns": {
          "type": "number",
          "default": 4,
          "description": "Maximum number of subagents to run per task."
        },
        "nexus.subagents.includeSecurity": {
          "type": "boolean",
          "default": false,
          "description": "Include the security review subagent when applicable."
        },
        "nexus.subagents.includeDocs": {
          "type": "boolean",
          "default": false,
          "description": "Include the docs subagent when applicable."
        },
        "nexus.agents.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable project-level markdown agent prompts and @agent autocomplete."
        },
        "nexus.agents.autoCopyDefaults": {
          "type": "boolean",
          "default": true,
          "description": "Copy bundled default agent prompts into .nexus/agents when missing."
        },
        "nexus.skills.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable project-level markdown skills and #skill autocomplete."
        },
        "nexus.skills.autoCopyDefaults": {
          "type": "boolean",
          "default": true,
          "description": "Copy bundled default skill prompts into .nexus/skills when missing."
        }
      }
    }
  },
  "scripts": {
    "compile:extension": "node esbuild.js",
    "compile:webview": "vite build",
    "compile": "npm run compile:extension && npm run compile:webview",
    "typecheck": "tsc -p ./ --noEmit",
    "build:cli": "node esbuild.js --cli",
    "watch": "node esbuild.js --watch",
    "watch:webview": "vite build --watch",
    "test:webview": "vitest run"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.7.0",
    "esbuild": "^0.25.12",
    "jsdom": "^26.1.0",
    "typescript": "^5.3.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.74.1",
    "@fluentui/react-icons": "^2.0.328",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "gpt-tokenizer": "^3.4.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  }
}
