{
  "name": "nexus-code",
  "displayName": "Nexus Code",
  "publisher": "NexusCode",
  "description": "A chat cockpit that routes prompts to installed CLI coding agents",
  "version": "1.0.0-beta",
  "icon": "media/extension-icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:nexus.chatView"
  ],
  "main": "./out/extension.js",
  "bin": {
    "nexus": "./out/cli/index.js"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nexus",
          "title": "Nexus",
          "icon": "media/nexus.svg"
        }
      ]
    },
    "views": {
      "nexus": [
        {
          "id": "nexus.chatView",
          "name": "Chat",
          "type": "webview",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "nexus.openChat",
        "title": "Nexus: Open Chat"
      },
      {
        "command": "nexus.openSettings",
        "title": "Nexus: Open Settings"
      }
    ],
    "configuration": {
      "title": "Nexus Code",
      "properties": {
        "nexus.defaultProvider": {
          "type": "string",
          "default": "nexus",
          "enum": [
            "nexus",
            "auto",
            "codex",
            "claude",
            "gemini",
            "copilot",
            "aider",
            "custom"
          ],
          "description": "The default CLI provider to use when routing tasks."
        },
        "nexus.customProvider.command": {
          "type": "string",
          "default": "",
          "description": "Executable for the custom provider. Use {{prompt}} as a placeholder."
        },
        "nexus.customProvider.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Arguments for the custom provider. Use {{prompt}} in any element as a placeholder."
        },
        "nexus.enablePromptEnhancement": {
          "type": "boolean",
          "default": true,
          "description": "Prepend workspace context to prompts before sending to the provider."
        },
        "nexus.showRawOutput": {
          "type": "boolean",
          "default": false,
          "description": "Show unfiltered stdout/stderr alongside parsed output."
        },
        "nexus.runGitStatusAfterTask": {
          "type": "boolean",
          "default": true,
          "description": "Run git status after each task completes and show changed files."
        }
      }
    }
  },
  "scripts": {
    "compile:extension": "node esbuild.js",
    "compile:webview": "vite build",
    "compile": "npm run compile:extension && npm run compile:webview",
    "typecheck": "tsc -p ./ --noEmit",
    "build:cli": "node esbuild.js --cli",
    "watch": "node esbuild.js --watch",
    "watch:webview": "vite build --watch",
    "test:webview": "vitest run"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.7.0",
    "esbuild": "^0.25.12",
    "jsdom": "^26.1.0",
    "typescript": "^5.3.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.74.1",
    "@fluentui/react-icons": "^2.0.328",
    "commander": "^12.1.0",
    "gpt-tokenizer": "^3.4.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  }
}
